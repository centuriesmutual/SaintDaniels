# Copy to .env on the server and fill in real values (never commit .env).
NEXT_PUBLIC_DOMAIN=https://your-production-domain.example

# MongoDB Atlas
# MONGODB_URI=

# Circle (adjust names to match your app)
# CIRCLE_API_KEY=
# CIRCLE_ENTITY_SECRET=

# Polygon
# POLYGON_RPC_URL=

# Google OAuth (if used)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# NextAuth (if used)
# NEXTAUTH_URL=https://your-production-domain.example
# NEXTAUTH_SECRET=
